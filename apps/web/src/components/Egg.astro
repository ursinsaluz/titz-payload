---
import { getIconByName } from '../lib/payload'

interface Props {
  name: string
  size?: number
  bg?: string
  pos?: string
  anim?: string
}

const { name, size = 60, bg = 'var(--mint)', pos = '', anim = '' } = Astro.props
const icon = await getIconByName(name)
---

{
  icon?.svg && (
    <span class="egg" style={`${pos}${anim ? `;animation:${anim}` : ''}`}>
      <button
        class="egg__btn"
        data-egg={name}
        aria-label={`Zutat: ${name}`}
        style={`width:${size}px;height:${size}px;background:${bg}`}
        set:html={icon.svg}
      />
    </span>
  )
}
