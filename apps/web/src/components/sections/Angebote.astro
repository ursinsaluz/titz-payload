---
import { getCollection } from '../../lib/payload'
import { lexicalToHtml } from '../../lib/lexical'
import IconCircle from '../IconCircle.astro'
import Egg from '../Egg.astro'

interface Angebot {
  id: number
  title: string
  eyebrow?: string
  icon?: unknown
  description?: unknown
  image?: unknown
  cta?: { label?: string; url?: string }
  order?: number
}

interface Props {
  block: {
    anchor?: string
    eyebrow?: string
    heading: string
    intro?: string
    angebote?: (Angebot | number)[] | null
  }
}

const { block } = Astro.props

let angebote: Angebot[]
const selected = (block.angebote ?? []).filter((a): a is Angebot => typeof a === 'object')
if (selected.length) {
  angebote = selected
} else {
  angebote = await getCollection<Angebot>('angebote', '&sort=order')
}

const cardColors = ['var(--blau)', 'var(--pfirsich)', 'var(--kraut)', 'var(--flieder)']
const cardTilts = ['-0.4deg', '0.4deg', '-0.4deg', '0.4deg']
---

<section class="angebote" id={block.anchor ?? 'angebote'}>
  <Egg name="apfel" size={60} bg="var(--kraut)" pos="right:4.5%;top:80px;transform-origin:50% -30%" anim="tzSwing 4.4s ease-in-out infinite" />
  <div class="container">
    <div class="section-head">
      {block.eyebrow && <div class="eyebrow">{block.eyebrow}</div>}
      <h2>{block.heading}</h2>
      {block.intro && <p class="angebote__intro">{block.intro}</p>}
    </div>
    <div class="angebote__grid" style={`grid-template-columns:repeat(${Math.min(angebote.length, 2)},1fr)`}>
      {
        angebote.map((angebot, index) => (
          <article
            data-rev={index * 140}
            class="angebote__card"
            style={`background:${cardColors[index % 4]};--card-tilt:${cardTilts[index % 4]}`}
          >
            {angebot.icon ? <IconCircle icon={angebot.icon as never} size={60} /> : null}
            <h3>{angebot.title}</h3>
            {angebot.description ? <div class="angebote__body" set:html={lexicalToHtml(angebot.description)} /> : null}
            {
              angebot.cta?.label && (
                <a class="pill pill--dark" href={angebot.cta.url ?? '#'}>
                  {angebot.cta.label}
                </a>
              )
            }
          </article>
        ))
      }
    </div>
  </div>
</section>

<style>
  .angebote {
    position: relative;
    padding: 66px 40px 100px;
    background: var(--bg-soft);
  }

  .angebote__intro {
    max-width: 560px;
    margin: 21px auto 0;
    color: var(--ink-70);
  }

  .angebote__grid {
    display: grid;
    gap: 26px;
  }

  .angebote__card {
    border-radius: 26px;
    padding: 47px 42px;
    display: flex;
    flex-direction: column;
    transition: transform 300ms;
  }

  .angebote__card:hover {
    transform: translateY(-6px) rotate(var(--card-tilt));
  }

  .angebote__card h3 {
    margin: 21px 0 10px;
    font-size: 24px;
  }

  .angebote__body {
    flex: 1;
  }

  .angebote__body :global(p) {
    margin: 0 0 13px;
    font-size: 14.5px;
    line-height: 1.7;
    color: var(--ink-70);
  }

  .angebote__body :global(p:has(strong:only-child)),
  .angebote__body :global(h3) {
    font-size: 15px;
  }

  .angebote__body :global(ul) {
    margin: 0 0 13px;
    padding-left: 20px;
    font-size: 13.5px;
    line-height: 1.65;
    color: var(--ink-55);
  }

  .angebote__card .pill {
    align-self: flex-start;
    margin-top: 17px;
  }

  @media (max-width: 860px) {
    .angebote__grid {
      grid-template-columns: 1fr !important;
    }
  }
</style>
