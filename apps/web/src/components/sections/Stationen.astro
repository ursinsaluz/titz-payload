---
import { getCollection } from '../../lib/payload'

interface Station {
  id: number
  group: string
  period?: string
  title: string
  place?: string
  description?: string
}

interface Props {
  block: {
    anchor?: string
    eyebrow?: string
    heading: string
    intro?: string
  }
  full?: boolean
}

const { block, full = false } = Astro.props
const stationen = await getCollection<Station>('stationen', '&sort=order')

const timeline = stationen.filter((s) => s.group === 'stationen')
const ausbildung = stationen.filter((s) => s.group === 'ausbildung')
const skills = stationen.filter((s) => s.group === 'qualifikationen')
const hobbies = stationen.filter((s) => s.group === 'hobbies')
const dotColors = ['var(--mint)', 'var(--cream)', 'var(--rosa)', 'var(--blau)', 'var(--flieder)', 'var(--kraut)', 'var(--pfirsich)', 'var(--sand)']
---

<section class="cv" id={block.anchor ?? 'lebenslauf'}>
  <div class="container">
    <div class="section-head">
      {block.eyebrow && <div class="eyebrow">{block.eyebrow}</div>}
      <h2>{block.heading}</h2>
      {block.intro && <p class="cv__intro">{block.intro}</p>}
    </div>
    <div class="cv__grid">
      <div class="cv__timeline-card" data-rev="0">
        <h3>Stationen</h3>
        <div>
          {
            timeline.map((station, index) => (
              <div class="cv__row">
                <div class="cv__rail">
                  <span class="cv__dot" style={`background:${dotColors[index % dotColors.length]}`} />
                  {index < timeline.length - 1 && <span class="cv__line" />}
                </div>
                <div class="cv__entry">
                  {station.period && <div class="cv__period">{station.period}</div>}
                  <div class="cv__title">{station.title}{station.place ? `, ${station.place}` : ''}</div>
                  {station.description && <div class="cv__text">{station.description}</div>}
                </div>
              </div>
            ))
          }
        </div>
      </div>
      <div class="cv__side">
        {
          skills.length ? (
            <div class="cv__card" style="background:var(--blau)" data-rev="100">
              <h3>Skills</h3>
              <div class="cv__chips">
                {skills.map((skill) => (
                  <span>{skill.title}</span>
                ))}
              </div>
            </div>
          ) : null
        }
        {
          ausbildung.length ? (
            <div class="cv__card" style="background:var(--cream)" data-rev="200">
              <h3>Ausbildung</h3>
              <div class="cv__list">
                {ausbildung.map((entry) => (
                  <div class="cv__list-item">
                    <strong>{entry.title}</strong>
                    {entry.place ? ` — ${entry.place}` : ''}
                    {full && entry.description && <div>{entry.description}</div>}
                  </div>
                ))}
              </div>
            </div>
          ) : null
        }
        {
          hobbies.length ? (
            <div class="cv__card" style="background:var(--mint)" data-rev="300">
              <h3>Freizeit</h3>
              <div class="cv__list">
                {hobbies.map((hobby, index) => (
                  <div>
                    {hobby.title}
                    {index === hobbies.length - 1 && (
                      <span data-egg-star style="cursor:pointer;color:var(--gold)">
                        {' '}
                        ✦
                      </span>
                    )}
                  </div>
                ))}
              </div>
            </div>
          ) : null
        }
      </div>
    </div>
  </div>
</section>

<style>
  .cv {
    position: relative;
    padding: 100px 40px;
    background: var(--bg);
  }

  .cv__intro {
    max-width: 560px;
    margin: 21px auto 0;
    color: var(--ink-70);
  }

  .cv__grid {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: 26px;
    align-items: start;
  }

  .cv__timeline-card {
    background: var(--bg-soft);
    border: 1.5px solid var(--rule);
    border-radius: 26px;
    padding: 42px 38px;
  }

  .cv__timeline-card > h3,
  .cv__card h3 {
    margin: 0 0 26px;
    font-size: 20px;
  }

  .cv__row {
    display: grid;
    grid-template-columns: 16px 1fr;
    gap: 16px;
  }

  .cv__rail {
    display: grid;
    justify-items: center;
    grid-template-rows: auto 1fr;
  }

  .cv__dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    border: 2px solid var(--green);
    margin-top: 4px;
  }

  .cv__line {
    width: 2px;
    background: rgba(47, 53, 56, 0.12);
  }

  .cv__entry {
    padding-bottom: 26px;
  }

  .cv__period {
    font-size: 11px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--gold);
  }

  .cv__title {
    font-weight: 700;
    font-size: 16px;
    margin: 3px 0 2px;
  }

  .cv__text {
    font-size: 13px;
    line-height: 1.6;
    color: rgba(47, 53, 56, 0.65);
  }

  .cv__side {
    display: grid;
    gap: 26px;
  }

  .cv__card {
    border-radius: 26px;
    padding: 38px 34px;
  }

  .cv__card h3 {
    margin-bottom: 18px;
  }

  .cv__chips {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .cv__chips span {
    font-size: 12px;
    background: #fff;
    border-radius: 999px;
    padding: 8px 15px;
  }

  .cv__list {
    font-size: 14px;
    line-height: 1.9;
    color: var(--ink-70);
  }

  .cv__list-item {
    margin-bottom: 13px;
  }

  @media (max-width: 860px) {
    .cv__grid {
      grid-template-columns: 1fr;
    }
  }
</style>
